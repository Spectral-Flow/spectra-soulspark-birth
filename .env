# SPECTRA - AI Soulmate Configuration
# Copy this file to .env and add your API keys
# 
# 🔐 Security Priority:
# - Backend API routes (most secure)
# - Client-side keys for development only
# - Multiple fallback layers for reliability

# =========================
# 🔒 Backend Environment Variables (SECURE - server-side ONLY)
# =========================

# Voice Services
ELEVENLABS_API_KEY=mock_elevenlabs_key_for_testing
OPENAI_API_KEY=mock_openai_key_for_testing
HUGGINGFACE_API_KEY=mock_huggingface_key_for_testing
OPENROUTER_API_KEY=mock_openrouter_key_for_testing

# Hugging Face Router (uses HF_TOKEN for router endpoint)
HF_TOKEN=mock_hf_token_for_testing

# Authentication & Security
JWT_SECRET=test-jwt-secret-change-in-production-min-32-chars

# Database Configuration (Optional)
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Platform Configuration
NODE_ENV=development
VERCEL_ENV=development
PORT=3000

# =========================
# 🌐 Frontend Environment Variables (client-safe)
# =========================

# Supabase Configuration (for Notes feature)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ElevenLabs Agent Configuration (safe to expose)
VITE_ELEVENLABS_AGENT_ID=agent_3001k351jqn1ex4tvqp9tj7srxqh

# Development Mode (ONLY when backend unavailable)
# Uncomment ONLY for local development
# VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# VITE_OPENAI_API_KEY=your_openai_api_key_here
# VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Debug Configuration
VITE_DEBUG=true
VITE_LOG_LEVEL=debug
LOG_LEVEL=debug

# =========================
# 🎵 Audio & Performance Configuration
# =========================

# Audio Processing
VITE_AUDIO_BUFFER_SIZE=4096
VITE_ENABLE_AUDIO_FALLBACKS=true
VITE_VOICE_RESPONSE_TIMEOUT=30000

# Performance Optimization
VITE_ENABLE_STREAMING=true
VITE_LAZY_LOAD_AI=true
VITE_USE_WEBGPU=auto

# =========================
# 🚀 Deployment Quick Reference
# =========================

# Vercel: Set backend variables in project settings
# Supabase: Set secrets via CLI: supabase secrets set KEY=value
# Supabase: Set secrets via CLI: supabase secrets set KEY=value
# 
# System Fallback Priority:
# 1. Backend API routes (🔒 secure, recommended)
# 2. Client-side VITE_ keys (⚠️ development only)
# 3. Web Speech API (📱 browser fallback)
# 4. Audio worklet with processor fallbacks
