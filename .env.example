# Spectra Backend Configuration
# Copy this file to .env and add your API keys

# Frontend Environment Variables (VITE_ prefixed for client-side access)
# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Get your Agent ID from the ElevenLabs dashboard
# For public agents, you can use this directly
# For private agents, you'll need the API key above
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here

# OpenAI API Configuration (optional, for enhanced voice features)
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Backend Environment Variables (for server-side API routes)
# ElevenLabs API (server-side, more secure)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API (server-side, more secure)
OPENAI_API_KEY=your_openai_api_key_here

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Database Configuration (Optional - for Supabase or PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Railway Configuration (if deploying to Railway)
RAILWAY_ENVIRONMENT=production

# Vercel Configuration
VERCEL_ENV=production

# Note: Backend API routes will use server-side keys (without VITE_ prefix)
# Frontend can still use VITE_ prefixed keys as fallback for development
# The system will automatically use available services in this priority order:
# 1. Backend API routes (if available)
# 2. ElevenLabs (if VITE_ELEVENLABS_API_KEY is set)
# 3. OpenAI (if VITE_OPENAI_API_KEY is set)
# 4. Web Speech API (browser fallback)
