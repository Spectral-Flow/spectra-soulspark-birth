# Copy to .env and fill values
# Hugging Face Inference API key (preferred for models like OpenHermes, Mistral)
# HUGGINGFACE_API_KEY=your_hf_token_here
# Optional: Hugging Face model id to use for text-generation (owner/model)
HF_MODEL=OpenAssistant/oa-OpenHermes-1.0
# Server-side Whisper model (for STT) when using Hugging Face Inference
HF_STT_MODEL=openai/whisper-large
## .env.example
# Copy this file to `.env` and fill in secrets. DO NOT commit your real API keys.

# -----------------------------
# Primary provider credentials
# -----------------------------
# Preferred LLM provider: Hugging Face Inference API
# HUGGINGFACE_API_KEY=your_hf_token_here
# Optional short alias some workflows accept
# HUGFACE=<same-as-above>

# Which HF model to use for text generation (example owner/model)
# Common options: OpenAssistant/oa-OpenHermes-1.0, MistralAI/mistral-7b, meta-llama/Llama-3
HF_MODEL=OpenAssistant/oa-OpenHermes-1.0

# Hugging Face model used for STT (Whisper) when doing server-side transcription
HF_STT_MODEL=openai/whisper-large


# Fallback provider: OpenAI (chat completions / chat API)
# Many environments use the name OPENAI_API_KEY, some scripts also accept OPENAI
OPENAI_API_KEY=
# OPENAI=your_openai_key_here


# -----------------------------
# ElevenLabs (TTS)
# -----------------------------
# ElevenLabs API key and voice id for high-quality TTS output
ELEVENLABS_API_KEY=
# Default example voice id (replace with one from your ElevenLabs account)
ELEVENLABS_VOICE_ID=A5RbnRGi2P2Tc7qilvMY

# Alternate secret name some deploys use (optional)
# SPECTRA_VOICE_API= (alias for ELEVENLABS_API_KEY / VOICE)
# VOICE= (legacy alias used in some scripts)


# -----------------------------
# Runtime/server settings
# -----------------------------
# Where the frontend should call the voice server (used by Vite build)
VITE_VOICE_SERVER_BASE=http://localhost:49231

# Port the local voice server listens on (used by scripts/voice-server.mjs and docker)
VOICE_PORT=49231


# -----------------------------
# GitHub Actions / Docker notes
# -----------------------------
# - In GitHub Actions use repository secrets (Settings → Secrets) and map them in workflows.
#   Recommended secret names to set in GitHub: HUGGINGFACE_API_KEY, OPENAI_API_KEY, ELEVENLABS_API_KEY,
#   ELEVENLABS_VOICE_ID, HF_MODEL (optional).
# - For Docker Compose, reference an env file or pass env variables via the compose file.

# Example: copy this file and edit
# cp .env.example .env

# SECURITY NOTE: Never commit `.env` to git. Add `.env` to .gitignore and use your host/ci secret manager.

# -----------------------------
# Troubleshooting hints
# -----------------------------
# - If the server logs "HF generation failed, falling back to OpenAI" then verify HUGGINGFACE_API_KEY and HF_MODEL.
# - If you see HTTP 404 / "Not Found" from HF, the model id may be incorrect or require auth; confirm model slug and that
#   your HF token has "inference" permissions.
# - For ElevenLabs, ensure the voice id exists in your account and the API key has TTS enabled.
