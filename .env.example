# Spectra Voice Configuration
# Copy this file to .env and add your API keys

# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Get your Agent ID from the ElevenLabs dashboard
# For public agents, you can use this directly
# For private agents, you'll need the API key above
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here

# OpenAI API Configuration (optional, for enhanced voice features)
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration (for Notes feature)
# Get these from your Supabase project dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Note: You only need one of the voice API keys
# The system will automatically use available services in this priority order:
# 1. ElevenLabs (if VITE_ELEVENLABS_API_KEY is set)
# 2. OpenAI (if VITE_OPENAI_API_KEY is set)
# 3. Web Speech API (browser fallback)
