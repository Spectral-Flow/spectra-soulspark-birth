# ElevenLabs Configuration
# Get your API key from: https://www.elevenlabs.io/sign-up
VITE_ELEVENLABS_API_KEY=your-api-key-here

# Get your Agent ID from the ElevenLabs dashboard
# For public agents, you can use this directly
# For private agents, you'll need the API key above
VITE_ELEVENLABS_AGENT_ID=your-agent-id-here

# OpenAI Configuration (optional, for enhanced voice features)
VITE_OPENAI_API_KEY=your-openai-api-key-here