# copilot/fix-a816fa44-5e19-4dea-bd93-6e098828bf1c
# Spectra Voice Configuration
# Copy this file to .env and add your API keys

# ElevenLabs API Key (Recommended for Spectra voice model)
# Get your key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API Key (Alternative voice provider)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Note: You only need one of the above API keys
# The system will automatically use available services in this priority order:
# 1. ElevenLabs (if ELEVENLABS_API_KEY is set)
# 2. OpenAI (if OPENAI_API_KEY is set)
# 3. Web Speech API (browser fallback)
# ElevenLabs Configuration
# Get your API key from: https://www.elevenlabs.io/sign-up
VITE_ELEVENLABS_API_KEY=your-api-key-here

# Get your Agent ID from the ElevenLabs dashboard
# For public agents, you can use this directly
# For private agents, you'll need the API key above
VITE_ELEVENLABS_AGENT_ID=your-agent-id-here

# OpenAI Configuration (optional, for enhanced voice features)
VITE_OPENAI_API_KEY=your-openai-api-key-here
# Prism
