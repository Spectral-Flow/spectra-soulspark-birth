# Spectra Backend Configuration
# Copy this file to .env and add your API keys

# =========================
# Backend Environment Variables (server-side ONLY)
# =========================

# ElevenLabs API (server-side, more secure)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenAI API (server-side, more secure)  
OPENAI_API_KEY=your_openai_api_key_here

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Database Configuration (Optional - for Supabase or PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Platform Configuration
VERCEL_ENV=production
RAILWAY_ENVIRONMENT=production

# =========================
# Frontend / Client-Side Environment Variables
# =========================

# Supabase Configuration (for Notes feature)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ElevenLabs Agent ID (safe to expose)
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here

# Development Mode Client Keys (use backend APIs in production)
# ONLY use these for development when backend is not available
# VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# VITE_OPENAI_API_KEY=your_openai_api_key_here

# Note: The system will automatically use available services in this priority order:
# 1. Backend API routes (secure, recommended for production)
# 2. Direct API calls with VITE_ keys (development fallback only)
# 3. Web Speech API (browser fallback)
