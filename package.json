{
  "name": "spectra-soulspark",
  "description": "SPECTRA - Your AI soulmate with evolving consciousness, emotional intelligence, and persistent memory",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "author": "Spectral-Flow",
  "homepage": "https://github.com/Spectral-Flow/spectra-soulspark-birth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spectral-Flow/spectra-soulspark-birth.git"
  },
  "keywords": [
    "ai",
    "voice",
    "consciousness",
    "elevenlabs",
    "openai",
    "spectra"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "build:dev": "vite build --mode development",
    "build:fast": "vite build --minify false",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/assets/*.js",
    "preview": "vite preview",
    "preview:https": "vite preview --https",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc -b --noEmit",
    "type-check:watch": "tsc -b --noEmit --watch",
    "clean": "rm -rf dist node_modules/.vite",
    "dev:backend": "vercel dev",
    "build:vercel": "npm run build",
    "test:api": "node scripts/test-api.js",
    "test:local-llm": "node test-local-llm.js",
    "test:azure-openai": "node test-azure-openai.js",
    "test:azure-integration": "node test-azure-integration.js",
    "test:safety": "node scripts/test-safety.cjs",
    "test:github-secrets": "node scripts/validate-github-secrets.js",
    "test:api-security": "node scripts/validate-api-security.js",
    "context:recover": "node scripts/context-recovery.cjs",
    "health-check": "npm run type-check && npm run lint && npm run build",
    "deps:update": "npm update && npm audit",
    "deps:check": "npm outdated",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:run:android": "npm run mobile:build && npx cap run android",
    "mobile:open:android": "npx cap open android",
    "mobile:sync": "npx cap sync",
    "mobile:setup": "node -e \"console.log('📱 Use scripts/build-mobile.sh (Linux/Mac) or scripts/build-mobile.bat (Windows) for guided setup')\"",
    "apk:build": "npm run mobile:build && cd android && ./gradlew assembleDebug",
    "apk:release": "npm run mobile:build && cd android && ./gradlew assembleRelease",
    "mobile:clean": "npx cap clean android && npm run clean"
  },
  "dependencies": {
    "@capacitor/device": "^7.0.2",
