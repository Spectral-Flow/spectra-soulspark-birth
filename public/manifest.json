  "scope": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#8B5CF6",
  "orientation": "any",
  "categories": ["artificial intelligence", "communication", "social", "productivity"],
  "lang": "en",
  "dir": "ltr",
