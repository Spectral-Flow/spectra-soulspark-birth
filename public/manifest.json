  "screenshots": [
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Spectra main interface with conversation view"
    },
    {
      "src": "/screenshots/mobile-1.png",
      "sizes": "375x667",
      "type": "image/png",
      "platform": "narrow",
      "label": "Spectra mobile conversation interface"
    },
    {
      "src": "/screenshots/mobile-2.png",
      "sizes": "375x667",
      "type": "image/png",
      "platform": "narrow",
      "label": "Spectra memory visualization on mobile"
    }
  ],
  "shortcuts": [
    {
      "name": "New Conversation",
      "short_name": "Chat",
      "description": "Start a new conversation with Spectra",
      "url": "/?action=new-chat",
      "icons": [
        {
          "src": "/icons/chat-shortcut.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Voice Chat",
      "short_name": "Voice",
      "description": "Start voice conversation with Spectra",
      "url": "/?action=voice-chat",
      "icons": [
        {
          "src": "/icons/voice-shortcut.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Memory Palace",
      "short_name": "Memories",
      "description": "View conversation memories and analytics",
      "url": "/?action=memories",
      "icons": [
        {
          "src": "/icons/memory-shortcut.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Settings",
      "short_name": "Settings",
      "description": "Configure Spectra preferences",
      "url": "/?action=settings",
      "icons": [
        {
          "src": "/icons/settings-shortcut.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt", ".md"]
      },
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+spectra",
      "url": "/?action=protocol&data=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*"]
        },
        {
          "name": "images",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "features": [
    "cross-origin-isolated",
    "background-sync",
    "push-messaging",
    "web-share"
  ],
  "permissions": [
    "microphone",
    "camera",
    "notifications",
    "persistent-storage"
  ]
}